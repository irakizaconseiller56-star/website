<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>UMUYOBORO TV</title>

  <!-- CSS -->
  <link rel="stylesheet" href="style.css">

  <!-- FONT AWESOME -->
  <link rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>

<body>

  <!-- HEADER -->
  <header id="home">

    <img src="logo.png" alt="Logo" class="logo">

    <h1>UMUYOBORO TV</h1>
    <p>Welcome to our official website</p>

    <!-- MOBILE MENU -->
    <div class="menu-icon" onclick="toggleMenu()">
      ☰
    </div>

    <!-- NAVIGATION -->
    <nav id="menu">
      <a href="#home">Home</a>
      <a href="#videos">Videos</a>
      <a href="#live">Live TV</a>
      <a href="#gallery">Gallery</a>
      <a href="#contact">Contact</a>
    </nav>

  </header>

  <!-- SLIDER -->
  <div class="slider">
    <img id="slider-image"
      src="https://picsum.photos/1200/500?1"
      alt="Slider Image">
  </div>

  <!-- HERO -->
  <section class="hero">

    <h2>Murakaza neza kuri UMUYOBORO TV</h2>

    <p>
      Aha ni ho usanga inyigisho,
      ubutumwa bwiza, videos nziza
      n’ibiganiro bitandukanye.
    </p>

  </section>

  <!-- VIDEOS -->
  <section id="videos">

    <h2>Latest Videos</h2>

    <div class="content">

      <!-- VIDEO CARD 1 -->
      <div class="video-card">

        <h3>Video 1</h3>

        <iframe width="100%" height="220"
          src="https://www.youtube.com/embed/Tha95QEdV-M"
          allowfullscreen>
        </iframe>

        <p>
          This is our first official video.
        </p>

        <button class="subscribe-btn"
          onclick="subscribeChannel()">
          Subscribe
        </button>

      </div>

      <!-- VIDEO CARD 2 -->
      <div class="video-card">

        <h3>Video 2</h3>

        <iframe width="100%" height="220"
          src="https://www.youtube.com/embed/jfKfPfyJRdk"
          allowfullscreen>
        </iframe>

        <p>
          Watch our latest live session.
        </p>

        <button class="subscribe-btn"
          onclick="subscribeChannel()">
          Subscribe
        </button>

      </div>

    </div>

  </section>

  <!-- LIVE TV -->
  <section class="live-tv" id="live">

    <h2>🔴 LIVE TV</h2>

    <iframe width="100%" height="350"
      src="https://www.youtube.com/embed/jfKfPfyJRdk"
      allowfullscreen>
    </iframe>

  </section>

  <!-- ABOUT -->
  <section class="about">

    <h2>About UMUYOBORO TV</h2>

    <p>
      UMUYOBORO TV ni channel itanga
      inyigisho, ubutumwa bwiza,
      amakuru ndetse n’ibiganiro
      bifasha abantu benshi.
    </p>

  </section>

  <!-- CONTENT CARDS -->
  <section class="content-section">

    <h2>Our Content</h2>

    <div class="content">

      <div class="card">
        <h3>Inyigisho</h3>
        <p>Dutanga inyigisho zitandukanye.</p>
      </div>

      <div class="card">
        <h3>Ubutumwa</h3>
        <p>Ijambo ry’Imana buri munsi.</p>
      </div>

      <div class="card">
        <h3>Live Programs</h3>
        <p>Live streaming z’amasengesho.</p>
      </div>

    </div>

  </section>

  <!-- GALLERY -->
  <section class="gallery" id="gallery">

    <h2>Gallery</h2>

    <div class="gallery-box">

      <img src="https://picsum.photos/400/300?1">
      <img src="https://picsum.photos/400/300?2">
      <img src="https://picsum.photos/400/300?3">
      <img src="https://picsum.photos/400/300?4">

    </div>

  </section>

  <!-- CONTACT -->
  <section class="contact" id="contact">

    <h2>Contact Us</h2>

    <p>
      <i class="fa-solid fa-envelope"></i>
      umuyoborotv@gmail.com
    </p>

    <p>
      <i class="fa-solid fa-phone"></i>
      +250 7XXXXXXXX
    </p>

    <p>
      <i class="fa-solid fa-location-dot"></i>
      Kigali - Rwanda
    </p>

  </section>

  <!-- FOOTER -->
  <footer>

    <h2>UMUYOBORO TV</h2>

    <p>
      Dukesha Imana ibikorwa byose 🙏
    </p>

    <!-- SOCIALS -->
    <div class="socials">

      <a href="#">
        <i class="fa-brands fa-youtube"></i>
      </a>

      <a href="#">
        <i class="fa-brands fa-facebook"></i>
      </a>

      <a href="#">
        <i class="fa-brands fa-instagram"></i>
      </a>

    </div>

    <p>
      © 2026 UMUYOBORO TV
      - All Rights Reserved
    </p>

  </footer>
<!-- JAVASCRIPT -->
<script>

  /* LOGIN PROTECTION */
  if (localStorage.getItem("loggedIn") !== "true") {

    window.location.href = "login.html";

  }

  /* MOBILE MENU */
  function toggleMenu() {

    document
      .getElementById("menu")
      .classList.toggle("show");

  }

  /* SUBSCRIBE */
  function subscribeChannel() {

    alert("Subscribed Successfully!");

    window.open(
      "https://youtube.com",
      "_blank"
    );

  }

  /* SLIDER */
  const images = [

    "https://picsum.photos/1200/500?1",

    "https://picsum.photos/1200/500?2",

    "https://picsum.photos/1200/500?3"

  ];

  let index = 0;

  setInterval(() => {

    index = (index + 1) % images.length;

    document
      .getElementById("slider-image")
      .src = images[index];

  }, 3000);

</script>
</body>
</html>